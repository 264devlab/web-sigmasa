<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="iisnode" path="app.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- Redirecciones 301 de WordPress viejo -->
        <rule name="Redirect Projects" stopProcessing="true">
          <match url="^index\.php/proyectos/.*" />
          <action type="Redirect" url="/#projects" redirectType="Permanent" />
        </rule>
        <rule name="Redirect Services Mining" stopProcessing="true">
          <match url="^index\.php/servicios-a-la-minera/.*" />
          <action type="Redirect" url="/#mining" redirectType="Permanent" />
        </rule>
        <rule name="Redirect Contact and Work" stopProcessing="true">
          <match url="^index\.php/(contacto|trabaja-con-nosotros)/.*" />
          <action type="Redirect" url="/#contact" redirectType="Permanent" />
        </rule>
        <rule name="Redirect General Sections" stopProcessing="true">
          <match url="^index\.php/(nosotros-empresa|ingenieria-proyecto-detalle|construccion|desarrollos-inmobiliarios-residenciales|clientes)/.*" />
          <action type="Redirect" url="/#services" redirectType="Permanent" />
        </rule>
        <rule name="Redirect index.php Root" stopProcessing="true">
          <match url="^index\.php/?$" />
          <action type="Redirect" url="/" redirectType="Permanent" />
        </rule>

        <!-- Reglas de la aplicación SPA -->
        <rule name="StaticContent" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>

        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="True" />
          </conditions>
          <action type="Rewrite" url="app.js" />
        </rule>
      </rules>
    </rewrite>

    <iisnode 
      node_env="production"
      debuggingEnabled="false"
      devErrorsEnabled="false"
    />

    <staticContent>
      <remove fileExtension=".webp" />
      <mimeMap fileExtension=".webp" mimeType="image/webp" />
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".webmanifest" />
      <mimeMap fileExtension=".webmanifest" mimeType="application/manifest+json" />
    </staticContent>
  </system.webServer>
</configuration>
